# maestro infra — site overlay TEMPLATE. Copy to config/<site>/.env and fill in.
# The real overlay is gitignored (instance data — ADR-0010).
#
#   cp .env.example config/ds1/.env
#   DOCKER_HOST=ssh://ds1 docker compose --env-file config/ds1/.env -f compose.yml up -d --build

MAESTRO_IMAGE_TAG=dev

# --- web (reviewer surface) ---
WEB_PORT=3034
WEB_BIND=0.0.0.0                      # 127.0.0.1 to keep it loopback-only + reach via Cloudflare/SSH
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000   # legacy build-time arg; S1 reads server-side (below)
# Where the webapp reads specs/designs from (server-side, runtime). Defaults to the orchestrator
# service on this network; only set this to override.
# MAESTRO_API_URL=http://orchestrator:8800
# Dev/stub workspace identity until component-auth (ADR-0019): a participant handle or email from the
# register. Leave EMPTY in production (Cloudflare Access + component-auth establishes the user).
MAESTRO_DEV_IDENTITY=

# --- orchestrator (workspace read API; ADR-0018) ---
# Absolute path on the DAEMON HOST to the private register (ADR-0010). Over a remote DOCKER_HOST (ds1),
# the file must already exist there — bind mounts resolve on the daemon host, not your laptop.
MAESTRO_REGISTER_HOST_PATH=/opt/maestro/config/products.yaml
# Authenticated GitHub reads (5000/hr) for the content path; unauthenticated is 60/hr (too low — the
# index scans docs/** per request). A fine-grained token with read access to the product repos.
GITHUB_TOKEN=
# The git ref a product's docs render from when no delivery task pins a branch (default: main).
MAESTRO_DEFAULT_BRANCH=main
# The read API's host binding for checks; loopback-only by default.
ORCH_BIND=127.0.0.1
ORCH_PORT=8800
