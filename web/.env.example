# maestro-web config template. Copy to .env.local (gitignored — ADR-0010) for local dev.
# NEXT_PUBLIC_* values are baked at build time; everything else is server-only.

# The orchestrator read API the workspace reads specs/designs from (S1, server-side — ADR-0018).
# `maestro serve` defaults to this. Server-only on purpose: the browser never calls the API directly,
# so it holds no token and no identity (ADR-0015).
MAESTRO_API_URL=http://127.0.0.1:8800

# Dev/stub workspace identity (ADR-0019): a participant email, forwarded as X-Maestro-Identity to the
# read API so render + isolation work before auth is wired. In production the Cloudflare Access +
# component-auth edge establishes this — leave it UNSET there.
MAESTRO_DEV_IDENTITY=you@example.com

# Auth (component-auth) — filled in when the auth slice lands (ADR-0019).
# AUTH_ISSUER_URL=
# AUTH_CLIENT_ID=
