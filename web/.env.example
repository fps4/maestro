# maestro-web config template. Copy to .env.local (gitignored — ADR-0010) for local dev.
# NEXT_PUBLIC_* values are baked at build time; everything else is server-only.

# Orchestrator API the webapp reads gate/event state from + posts decisions to (US-0030).
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000

# Auth (component-auth) — filled in when auth is wired.
# AUTH_ISSUER_URL=
# AUTH_CLIENT_ID=
